{
  "name": "imyloc",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "iMyLoc iOS Location Spoofer",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:exe": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.imyloc.app",
    "productName": "iMyLoc",
    "directories": {
      "output": "release/"
    },
    "win": {
      "target": "dir",
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "../iMyLoc-Logo.ico"
    },
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend",
        "filter": [
          "backend.exe"
        ]
      }
    ]
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "axios": "^1.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-joystick-component": "^6.2.1",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
